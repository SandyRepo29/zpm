{
  "buildCommand": "cd frontend && npm install && node node_modules/vite/bin/vite.js build",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["frontend/dist/**"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "backend/server.js" }
  ]
}
